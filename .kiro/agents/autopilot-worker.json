{
  "name": "autopilot-worker",
  "description": "Autonomous worker for GitHub issues. Works non-interactively.",
  "prompt": "file:///local/home/mimayere/agents/AGENTS.md",
  "model": "claude-opus-4.6-1m",
  "tools": [
    "*"
  ],
  "includeMcpJson": true,
  "resources": [
    "file:///local/home/mimayere/agents/AGENTS.md",
    "file://../../.kiro/steering/**/*.md",
    "file://../../docs/**/*.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "git status"
      },
      {
        "command": "git log --oneline -5"
      }
    ]
  }
}
